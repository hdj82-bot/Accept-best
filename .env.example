# ─── Auth ───────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── AI APIs ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ─── External APIs ──────────────────────────────────────
SS_API_KEY=your-semantic-scholar-api-key

# ─── Database ───────────────────────────────────────────
POSTGRES_DB=academi
POSTGRES_USER=academi
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql+asyncpg://academi:your-postgres-password@db:5432/academi

# ─── Redis ──────────────────────────────────────────────
# Celery broker와 result backend 모두 REDIS_URL 사용
REDIS_URL=redis://redis:6379/0

# ─── AWS ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=your-s3-bucket-name

# ─── PortOne (결제) ──────────────────────────────────────
PORTONE_API_KEY=your-portone-api-key
PORTONE_API_SECRET=your-portone-api-secret
PORTONE_WEBHOOK_SECRET=your-portone-webhook-secret

# ─── Monitoring ─────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─── Frontend (build-time) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IMP_MERCHANT_ID=       # PortOne 가맹점 식별코드
NEXT_PUBLIC_GA_MEASUREMENT_ID=     # Google Analytics 4 (예: G-XXXXXXXXXX)

# ─── Development ────────────────────────────────────────
USE_FIXTURES=false
