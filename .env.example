# 인증 (next-auth와 FastAPI 동일 값 필수)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI API
GEMINI_API_KEY=          # 텍스트 생성 + 임베딩(1536차원) 통합

# 번역 (Phase 2에서 활성화)
DEEPL_API_KEY=

# 논문 수집
SS_API_KEY=              # Semantic Scholar, 일 1,000건 무료

# 인프라
# 로컬 docker-compose에서 db 컨테이너 자격증명을 변수로 주입
POSTGRES_USER=academi
POSTGRES_PASSWORD=academi
POSTGRES_DB=academi
DATABASE_URL=postgresql+asyncpg://academi:academi@db:5432/academi  # Neon: postgresql+asyncpg://user:pass@host/dbname
REDIS_URL=redis://redis:6379/0  # Upstash: rediss://default:pass@host:6379
SENTRY_DSN=

# 클라우드 배포 시
CELERY_DISABLED=1        # Celery 미사용 시 동기 실행
NEXT_PUBLIC_API_URL=     # Vercel에서 Render 백엔드 URL

# CORS (쉼표 구분, 프로덕션 시 실제 도메인으로 변경)
CORS_ORIGINS=["http://localhost:3000"]

# AWS (선택)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# 개발 편의
USE_FIXTURES=true        # 개발 중 true, 배포 시 false
