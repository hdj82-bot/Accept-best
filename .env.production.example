# ╔══════════════════════════════════════════════════════════════════╗
# ║  academi.ai — 프로덕션 환경변수 템플릿                            ║
# ║  이 파일을 .env로 복사하여 실제 값을 입력하세요                      ║
# ║  cp .env.production.example .env                                ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Domain ─────────────────────────────────────────────
DOMAIN=academi.ai
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# ─── Auth ───────────────────────────────────────────────
NEXTAUTH_SECRET=          # openssl rand -base64 32
NEXTAUTH_URL=https://academi.ai
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─── AI APIs ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ─── Translation ────────────────────────────────────────
DEEPL_API_KEY=

# ─── External APIs ──────────────────────────────────────
SS_API_KEY=               # Semantic Scholar

# ─── Database ───────────────────────────────────────────
POSTGRES_DB=academi
POSTGRES_USER=academi
POSTGRES_PASSWORD=        # openssl rand -base64 24
DATABASE_URL=postgresql+asyncpg://academi:YOUR_PASSWORD@db:5432/academi

# ─── Redis ──────────────────────────────────────────────
# Celery broker와 result backend 모두 REDIS_URL 사용
REDIS_URL=redis://redis:6379/0

# ─── AWS S3 (PDF 내보내기 저장) ──────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=academi-exports

# ─── PortOne 결제 ───────────────────────────────────────
PORTONE_API_KEY=
PORTONE_API_SECRET=
PORTONE_WEBHOOK_SECRET=

# ─── Monitoring ─────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ─── CORS ───────────────────────────────────────────────
CORS_ORIGINS=https://academi.ai

# ─── Production flags ──────────────────────────────────
USE_FIXTURES=false
DEBUG=false

# ─── Frontend (build-time) ──────────────────────────────
NEXT_PUBLIC_API_URL=https://academi.ai/api
NEXT_PUBLIC_APP_URL=https://academi.ai
NEXT_PUBLIC_IMP_MERCHANT_ID=       # PortOne 가맹점 식별코드
NEXT_PUBLIC_USE_FIXTURES=false
